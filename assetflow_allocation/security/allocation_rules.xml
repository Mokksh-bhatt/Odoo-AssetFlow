<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ALLOCATION RULES -->
        <record id="rule_allocation_employee" model="ir.rule">
            <field name="name">AssetFlow Allocation: Employee</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[('employee_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_allocation_dept_head" model="ir.rule">
            <field name="name">AssetFlow Allocation: Dept Head</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">['|', ('employee_id', '=', user.id), ('department_id', 'child_of', [user.assetflow_department_id.id])]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_department_head'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_allocation_manager" model="ir.rule">
            <field name="name">AssetFlow Allocation: Manager/Admin</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_asset_manager')), (4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- TRANSFER REQUEST RULES -->
        <record id="rule_transfer_employee" model="ir.rule">
            <field name="name">AssetFlow Transfer: Employee</field>
            <field name="model_id" ref="model_assetflow_transfer_request"/>
            <field name="domain_force">[('requester_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_transfer_dept_head" model="ir.rule">
            <field name="name">AssetFlow Transfer: Dept Head</field>
            <field name="model_id" ref="model_assetflow_transfer_request"/>
            <field name="domain_force">['|', ('requester_id', '=', user.id), ('target_department_id', 'child_of', [user.assetflow_department_id.id])]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_department_head'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_transfer_manager" model="ir.rule">
            <field name="name">AssetFlow Transfer: Manager/Admin</field>
            <field name="model_id" ref="model_assetflow_transfer_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_asset_manager')), (4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
