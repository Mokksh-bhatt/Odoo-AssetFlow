<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_allocation_tree" model="ir.ui.view">
        <field name="name">assetflow.allocation.tree</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <tree string="Allocations" decoration-success="status == 'active'" decoration-muted="status == 'returned'">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="department_id" optional="show"/>
                <field name="allocation_date"/>
                <field name="expected_return_date" optional="show"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'returned'"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_allocation_form" model="ir.ui.view">
        <field name="name">assetflow.allocation.form</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <form string="Allocation">
                <header>
                    <button name="action_return" string="Return Asset" type="object" class="oe_highlight" invisible="status == 'returned'"/>
                    <field name="status" widget="statusbar" statusbar_visible="active,returned"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Returned" bg_color="text-bg-success" invisible="status == 'active'"/>
                    <group>
                        <group string="Assignment">
                            <field name="asset_id" readonly="status == 'returned'" options="{'no_create': True}"/>
                            <field name="employee_id" readonly="status == 'returned'"/>
                            <field name="department_id" readonly="1"/>
                            <field name="allocated_by" readonly="1"/>
                        </group>
                        <group string="Dates">
                            <field name="allocation_date" readonly="status == 'returned'"/>
                            <field name="expected_return_date" readonly="status == 'returned'"/>
                            <field name="actual_return_date" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Return Condition Notes" invisible="status == 'returned' and not return_condition_notes">
                            <field name="return_condition_notes" placeholder="Please document the condition of the asset before returning..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_allocation_search" model="ir.ui.view">
        <field name="name">assetflow.allocation.search</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <search string="Search Allocations">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <separator/>
                <filter string="Active" name="active" domain="[('status', '=', 'active')]"/>
                <filter string="Returned" name="returned" domain="[('status', '=', 'returned')]"/>
                <group expand="0" string="Group By">
                    <filter string="Asset" name="group_by_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="Employee" name="group_by_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_assetflow_allocation" model="ir.actions.act_window">
        <field name="name">Allocations</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_assetflow_allocation_search"/>
        <field name="context">{'search_default_active': 1}</field>
    </record>
</odoo>
