<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_transfer_request_tree" model="ir.ui.view">
        <field name="name">assetflow.transfer.request.tree</field>
        <field name="model">assetflow.transfer.request</field>
        <field name="arch" type="xml">
            <tree string="Transfer Requests" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'">
                <field name="asset_id"/>
                <field name="requester_id"/>
                <field name="target_employee_id"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'submitted'" 
                       decoration-success="state == 'approved'" 
                       decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_transfer_request_form" model="ir.ui.view">
        <field name="name">assetflow.transfer.request.form</field>
        <field name="model">assetflow.transfer.request</field>
        <field name="arch" type="xml">
            <form string="Transfer Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="assetflow_base.group_assetflow_asset_manager,assetflow_base.group_assetflow_department_head"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'submitted'" groups="assetflow_base.group_assetflow_asset_manager,assetflow_base.group_assetflow_department_head"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,rejected"/>
                </header>
                <sheet>
                    <group>
                        <group string="Details">
                            <field name="asset_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="requester_id" readonly="1"/>
                            <field name="current_holder_id"/>
                        </group>
                        <group string="Target">
                            <field name="target_employee_id" readonly="state != 'draft'"/>
                            <field name="target_department_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Reason">
                            <field name="reason" placeholder="Why is this transfer needed?" readonly="state != 'draft'"/>
                        </page>
                        <page string="Approval Details" invisible="state in ('draft', 'submitted')">
                            <group>
                                <field name="approver_id" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                                <field name="rejection_reason" readonly="1" invisible="state != 'rejected'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_transfer_request_search" model="ir.ui.view">
        <field name="name">assetflow.transfer.request.search</field>
        <field name="model">assetflow.transfer.request</field>
        <field name="arch" type="xml">
            <search string="Search Transfer Requests">
                <field name="asset_id"/>
                <field name="requester_id"/>
                <field name="target_employee_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Asset" name="group_by_asset" context="{'group_by': 'asset_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_assetflow_transfer_request" model="ir.actions.act_window">
        <field name="name">Transfer Requests</field>
        <field name="res_model">assetflow.transfer.request</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_assetflow_transfer_request_search"/>
    </record>
</odoo>
