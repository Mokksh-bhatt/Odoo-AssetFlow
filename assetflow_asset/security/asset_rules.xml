<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_asset_employee" model="ir.rule">
            <field name="name">AssetFlow Asset: Employee Read</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="domain_force">['|', '|', ('current_holder_employee_id', '=', user.id), ('current_holder_department_id', 'child_of', user.assetflow_department_id.ids), ('is_bookable', '=', True)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_asset_manager" model="ir.rule">
            <field name="name">AssetFlow Asset: Manager/Admin Full</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_asset_manager')), (4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
