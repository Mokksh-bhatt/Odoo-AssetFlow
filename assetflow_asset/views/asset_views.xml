<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_assetflow_asset_tree" model="ir.ui.view">
        <field name="name">assetflow.asset.tree</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <list string="Assets" decoration-info="state == 'available'" decoration-success="state == 'allocated'" decoration-warning="state == 'maintenance'" decoration-danger="state == 'lost'">
                <field name="asset_tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="current_holder_department_id" optional="show"/>
                <field name="current_holder_employee_id" optional="show"/>
                <field name="location_id" optional="show"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'available'" 
                       decoration-success="state == 'allocated'" 
                       decoration-warning="state == 'maintenance'" 
                       decoration-danger="state == 'lost'"/>
            </list>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_assetflow_asset_kanban" model="ir.ui.view">
        <field name="name">assetflow.asset.kanban</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="location_id"/>
                <field name="current_holder_employee_id"/>
                <field name="image"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <div class="o_kanban_image d-none d-md-block" t-attf-style="background-image:url('/web/image/assetflow.asset/#{record.id.raw_value}/image')">
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <small class="o_kanban_record_subtitle text-muted">
                                            <field name="asset_tag"/>
                                        </small>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-2">
                                    <div><field name="category_id"/></div>
                                    <div t-if="record.location_id.raw_value"><i class="fa fa-map-marker" title="Location" role="img" aria-label="Location"/> <field name="location_id"/></div>
                                    <div t-if="record.current_holder_employee_id.raw_value"><i class="fa fa-user" title="Holder" role="img" aria-label="Holder"/> <field name="current_holder_employee_id"/></div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="label_selection" 
                                               options="{'classes': {'available': 'info', 'allocated': 'success', 'maintenance': 'warning', 'lost': 'danger', 'retired': 'default', 'disposed': 'default'}}"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_assetflow_asset_form" model="ir.ui.view">
        <field name="name">assetflow.asset.form</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <!-- Read-only status bar, state changes happen via dedicated actions/buttons from dependent modules -->
                    <field name="state" widget="statusbar" statusbar_visible="available,allocated,maintenance,lost,retired"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. ThinkPad T14"/>
                        </h1>
                        <label for="asset_tag" class="oe_edit_only"/>
                        <h2>
                            <field name="asset_tag" placeholder="Auto-generated"/>
                        </h2>
                    </div>
                    
                    <group>
                        <group string="General Information">
                            <field name="category_id"/>
                            <field name="serial_number"/>
                            <field name="qr_code"/>
                            <field name="condition"/>
                        </group>
                        <group string="Assignment">
                            <field name="current_holder_department_id"/>
                            <field name="location_id"/>
                            <field name="current_holder_employee_id"/>
                        </group>
                        <group string="Acquisition">
                            <field name="acquisition_date"/>
                            <!-- Assuming standard res.currency interaction is omitted or handled globally via Odoo monetary widget -->
                            <field name="acquisition_cost" widget="monetary"/>
                        </group>
                        <group string="Options">
                            <field name="is_bookable"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Category Values" name="category_values">
                            <field name="category_value_ids">
                                <list editable="bottom">
                                    <field name="category_field_id" domain="[('category_id', '=', parent.category_id)]" options="{'no_create': True}"/>
                                    <field name="value_char" column_invisible="parent.category_id == False"/>
                                    <field name="value_integer" column_invisible="parent.category_id == False"/>
                                    <field name="value_float" column_invisible="parent.category_id == False"/>
                                    <field name="value_boolean" column_invisible="parent.category_id == False"/>
                                    <field name="value_date" column_invisible="parent.category_id == False"/>
                                </list>
                            </field>
                        </page>
                        <page string="State History" name="state_history">
                            <field name="state_log_ids" readonly="1">
                                <list>
                                    <field name="change_date"/>
                                    <field name="old_state"/>
                                    <field name="new_state"/>
                                    <field name="changed_by"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Mail mixin rendering (Chatter) -->
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_assetflow_asset_search" model="ir.ui.view">
        <field name="name">assetflow.asset.search</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name"/>
                <field name="asset_tag"/>
                <field name="serial_number"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="current_holder_department_id"/>
                <field name="location_id"/>
                
                <separator/>
                <filter string="Bookable" name="is_bookable" domain="[('is_bookable', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                
                <group>
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'current_holder_department_id'}"/>
                    <filter string="Location" name="group_by_location" context="{'group_by': 'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_assetflow_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_assetflow_asset_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register a new asset
            </p>
            <p>
                Keep track of your company's physical assets, their location, state, and assignments.
            </p>
        </field>
    </record>
</odoo>
