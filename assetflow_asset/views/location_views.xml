<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_assetflow_location_tree" model="ir.ui.view">
        <field name="name">assetflow.location.tree</field>
        <field name="model">assetflow.location</field>
        <field name="arch" type="xml">
            <tree string="Locations">
                <field name="code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_assetflow_location_form" model="ir.ui.view">
        <field name="name">assetflow.location.form</field>
        <field name="model">assetflow.location</field>
        <field name="arch" type="xml">
            <form string="Location">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Server Room A"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="department_id"/>
                        </group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_assetflow_location_search" model="ir.ui.view">
        <field name="name">assetflow.location.search</field>
        <field name="model">assetflow.location</field>
        <field name="arch" type="xml">
            <search string="Search Locations">
                <field name="name"/>
                <field name="code"/>
                <field name="department_id"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_assetflow_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">assetflow.location</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_assetflow_location_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new location
            </p>
            <p>
                Manage physical locations where your assets are deployed.
            </p>
        </field>
    </record>
</odoo>
