<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_audit_discrepancy_list" model="ir.ui.view">
        <field name="name">assetflow.audit.discrepancy.list</field>
        <field name="model">assetflow.audit.discrepancy</field>
        <field name="arch" type="xml">
            <list string="Discrepancies">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="issue_type"/>
                <field name="cycle_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_audit_discrepancy_form" model="ir.ui.view">
        <field name="name">assetflow.audit.discrepancy.form</field>
        <field name="model">assetflow.audit.discrepancy</field>
        <field name="arch" type="xml">
            <form string="Discrepancy">
                <header>
                    <button name="action_resolve" string="Mark as Resolved" type="object" class="oe_highlight" invisible="state == 'resolved'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved,rejected,resolved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="line_id" readonly="1"/>
                            <field name="asset_id" readonly="1"/>
                            <field name="cycle_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="issue_type" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details">
                            <group>
                                <field name="description"/>
                                <field name="resolution"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_audit_discrepancy" model="ir.actions.act_window">
        <field name="name">Audit Discrepancies</field>
        <field name="res_model">assetflow.audit.discrepancy</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
