<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_assetflow" model="ir.module.category">
            <field name="name">AssetFlow</field>
            <field name="description">Helps you manage your assets and resources.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_assetflow_employee" model="res.groups">
            <field name="name">Employee</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Basic access for employees to request and view assets.</field>
        </record>

        <record id="group_assetflow_department_head" model="res.groups">
            <field name="name">Department Head</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
            <field name="comment">Access for department heads to manage their department's assets and approve requests.</field>
        </record>

        <record id="group_assetflow_asset_manager" model="res.groups">
            <field name="name">Asset Manager</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
            <field name="comment">Access for asset managers to manage all assets, categories, and inventory.</field>
        </record>

        <record id="group_assetflow_admin" model="res.groups">
            <field name="name">Admin</field>
            <field name="category_id" ref="module_category_assetflow"/>
            <field name="implied_ids" eval="[(4, ref('group_assetflow_department_head')), (4, ref('group_assetflow_asset_manager'))]"/>
            <field name="comment">Full administrative access to all AssetFlow features.</field>
        </record>
    </data>
</odoo>
