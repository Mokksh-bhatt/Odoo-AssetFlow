<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_category_form" model="ir.ui.view">
        <field name="name">assetflow.category.form</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Custom Fields" name="custom_fields">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="field_type"/>
                                    <field name="required"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_assetflow_category_tree" model="ir.ui.view">
        <field name="name">assetflow.category.tree</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="view_assetflow_category_search" model="ir.ui.view">
        <field name="name">assetflow.category.search</field>
        <field name="model">assetflow.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_assetflow_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">assetflow.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_assetflow_category_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Category
            </p>
        </field>
    </record>

    <menuitem id="menu_assetflow_category" 
              name="Categories" 
              parent="menu_assetflow_organization_setup" 
              action="action_assetflow_category" 
              sequence="20"/>
</odoo>
