<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_department_form" model="ir.ui.view">
        <field name="name">assetflow.department.form</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Department Name..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="parent_id"/>
                            <field name="department_head_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Child Departments" name="child_departments">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="department_head_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_assetflow_department_tree" model="ir.ui.view">
        <field name="name">assetflow.department.tree</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <list string="Departments">
                <field name="display_name" string="Department"/>
                <field name="department_head_id"/>
            </list>
        </field>
    </record>

    <record id="view_assetflow_department_search" model="ir.ui.view">
        <field name="name">assetflow.department.search</field>
        <field name="model">assetflow.department</field>
        <field name="arch" type="xml">
            <search string="Search Departments">
                <field name="name"/>
                <field name="department_head_id"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Parent Department" name="group_parent_id" context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_assetflow_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">assetflow.department</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_assetflow_department_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Department
            </p>
        </field>
    </record>

    <menuitem id="menu_assetflow_department" 
              name="Departments" 
              parent="menu_assetflow_organization_setup" 
              action="action_assetflow_department" 
              sequence="10"/>
</odoo>
