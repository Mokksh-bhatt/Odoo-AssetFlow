<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_assetflow" model="ir.ui.view">
        <field name="name">res.users.form.assetflow</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="AssetFlow" name="assetflow_info">
                    <group>
                        <group>
                            <field name="employee_code"/>
                            <field name="assetflow_department_id"/>
                            <field name="assetflow_role"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_users_preferences_form_assetflow" model="ir.ui.view">
        <field name="name">res.users.preferences.form.assetflow</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="AssetFlow" name="assetflow_info">
                    <group>
                        <group>
                            <field name="employee_code" readonly="1"/>
                            <field name="assetflow_department_id" readonly="1"/>
                            <field name="assetflow_role" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_assetflow_employee_directory" model="ir.actions.act_window">
        <field name="name">Employee Directory</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_assetflow_employee_directory" 
              name="Employee Directory" 
              parent="menu_assetflow_organization_setup" 
              action="action_assetflow_employee_directory" 
              sequence="30"/>
</odoo>
