<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Update Booking Status -->
        <record id="ir_cron_update_booking_status" model="ir.cron">
            <field name="name">AssetFlow: Update Booking Status</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="state">code</field>
            <field name="code">model._update_booking_status()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Send Booking Reminders -->
        <record id="ir_cron_send_booking_reminders" model="ir.cron">
            <field name="name">AssetFlow: Send Booking Reminders</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="state">code</field>
            <field name="code">model._send_reminders()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
