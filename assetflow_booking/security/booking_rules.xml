<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule for Employees -->
        <record id="rule_assetflow_booking_employee" model="ir.rule">
            <field name="name">AssetFlow Booking: Employee Personal</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[('booked_by_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Rule for Department Heads -->
        <record id="rule_assetflow_booking_dept_head" model="ir.rule">
            <field name="name">AssetFlow Booking: Department Head</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">['|', ('booked_by_id', '=', user.id), ('department_id', 'child_of', [user.assetflow_department_id.id])]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_department_head'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Rule for Managers and Admins -->
        <record id="rule_assetflow_booking_manager" model="ir.rule">
            <field name="name">AssetFlow Booking: Manager Unrestricted</field>
            <field name="model_id" ref="model_assetflow_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_asset_manager')), (4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
