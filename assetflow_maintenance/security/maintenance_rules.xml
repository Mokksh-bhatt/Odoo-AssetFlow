<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_maintenance_employee" model="ir.rule">
            <field name="name">AssetFlow Maintenance: Employee</field>
            <field name="model_id" ref="model_assetflow_maintenance"/>
            <field name="domain_force">[('requested_by', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_maintenance_dept_head" model="ir.rule">
            <field name="name">AssetFlow Maintenance: Dept Head</field>
            <field name="model_id" ref="model_assetflow_maintenance"/>
            <field name="domain_force">['|', ('requested_by', '=', user.id), ('department_id', 'child_of', [user.assetflow_department_id.id])]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_department_head'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_maintenance_manager" model="ir.rule">
            <field name="name">AssetFlow Maintenance: Manager/Admin</field>
            <field name="model_id" ref="model_assetflow_maintenance"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_asset_manager')), (4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
