<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_assetflow_maintenance_tree" model="ir.ui.view">
        <field name="name">assetflow.maintenance.tree</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests" decoration-info="state == 'draft'" decoration-warning="state == 'submitted'" decoration-success="state == 'completed'" decoration-danger="state == 'rejected'">
                <field name="name"/>
                <field name="asset_id"/>
                <field name="maintenance_type"/>
                <field name="priority" widget="priority"/>
                <field name="request_date"/>
                <field name="scheduled_date"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'submitted'" 
                       decoration-primary="state == 'approved'"
                       decoration-success="state == 'completed'" 
                       decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_assetflow_maintenance_form" model="ir.ui.view">
        <field name="name">assetflow.maintenance.form</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="assetflow_base.group_assetflow_asset_manager,assetflow_base.group_assetflow_department_head"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'submitted'" groups="assetflow_base.group_assetflow_asset_manager,assetflow_base.group_assetflow_department_head"/>
                    <button name="action_complete" string="Complete" type="object" class="oe_highlight" invisible="state != 'approved'" groups="assetflow_base.group_assetflow_asset_manager,assetflow_base.group_assetflow_department_head"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="asset_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="requested_by" readonly="state != 'draft'"/>
                            <field name="department_id" readonly="1"/>
                            <field name="technician_id" readonly="state in ('completed', 'rejected')"/>
                        </group>
                        <group string="Details">
                            <field name="maintenance_type" readonly="state != 'draft'"/>
                            <field name="priority" widget="priority" readonly="state != 'draft'"/>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="scheduled_date" readonly="state in ('completed', 'rejected')"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="General">
                            <field name="description" placeholder="Describe the maintenance issue or requirement..." readonly="state != 'draft'"/>
                        </page>
                        <page string="Work Details" invisible="state in ('draft', 'submitted')">
                            <group>
                                <group>
                                    <field name="completion_date" readonly="state == 'completed'"/>
                                    <field name="estimated_cost" readonly="state == 'completed'"/>
                                    <field name="actual_cost" readonly="state == 'completed'"/>
                                </group>
                            </group>
                            <separator string="Work Performed"/>
                            <field name="work_performed" placeholder="Details of work performed..." readonly="state == 'completed'"/>
                        </page>
                        <page string="Approval" invisible="state in ('draft', 'submitted')">
                            <group>
                                <field name="approver_id" readonly="1"/>
                                <field name="approval_date" readonly="1"/>
                                <field name="rejection_reason" readonly="1" invisible="state != 'rejected'"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_assetflow_maintenance_calendar" model="ir.ui.view">
        <field name="name">assetflow.maintenance.calendar</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <calendar string="Maintenance" date_start="scheduled_date" color="state">
                <field name="asset_id"/>
                <field name="technician_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_assetflow_maintenance_search" model="ir.ui.view">
        <field name="name">assetflow.maintenance.search</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="asset_id"/>
                <field name="technician_id"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state', 'in', ('draft', 'submitted'))]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <filter string="Preventive" name="preventive" domain="[('maintenance_type', '=', 'preventive')]"/>
                <filter string="Corrective" name="corrective" domain="[('maintenance_type', '=', 'corrective')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Technician" name="group_by_technician" context="{'group_by': 'technician_id'}"/>
                    <filter string="Asset" name="group_by_asset" context="{'group_by': 'asset_id'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_assetflow_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="search_view_id" ref="view_assetflow_maintenance_search"/>
    </record>
</odoo>
