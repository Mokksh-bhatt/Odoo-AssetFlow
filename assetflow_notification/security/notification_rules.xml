<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule for Employees (implied for Dept Head & Asset Manager) -->
        <record id="rule_assetflow_notification_personal" model="ir.rule">
            <field name="name">AssetFlow Notification: Personal Inbox</field>
            <field name="model_id" ref="model_assetflow_notification"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_employee'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Rule for Admin: Unrestricted -->
        <record id="rule_assetflow_notification_admin" model="ir.rule">
            <field name="name">AssetFlow Notification: Admin Unrestricted</field>
            <field name="model_id" ref="model_assetflow_notification"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('assetflow_base.group_assetflow_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
