<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_assetflow_notification_tree" model="ir.ui.view">
        <field name="name">assetflow.notification.tree</field>
        <field name="model">assetflow.notification</field>
        <field name="arch" type="xml">
            <tree string="Notifications" decoration-bf="not is_read">
                <field name="create_date" string="Date"/>
                <field name="title"/>
                <field name="notification_type"/>
                <field name="is_read" widget="boolean_toggle"/>
                <button name="action_mark_as_read" string="Mark as Read" type="object" icon="fa-check" invisible="is_read"/>
                <button name="action_view_related_record" string="View Record" type="object" icon="fa-external-link" invisible="not res_model"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_assetflow_notification_form" model="ir.ui.view">
        <field name="name">assetflow.notification.form</field>
        <field name="model">assetflow.notification</field>
        <field name="arch" type="xml">
            <form string="Notification">
                <header>
                    <button name="action_mark_as_read" string="Mark as Read" type="object" class="oe_highlight" invisible="is_read"/>
                    <button name="action_view_related_record" string="View Related Record" type="object" class="btn-secondary" invisible="not res_model"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="title" class="oe_edit_only"/>
                        <h1>
                            <field name="title" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="notification_type" readonly="1"/>
                            <field name="is_read" readonly="1"/>
                        </group>
                        <group>
                            <field name="create_date" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="res_model" invisible="1"/>
                            <field name="res_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Message Body">
                            <field name="body" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_assetflow_notification_search" model="ir.ui.view">
        <field name="name">assetflow.notification.search</field>
        <field name="model">assetflow.notification</field>
        <field name="arch" type="xml">
            <search string="Search Notifications">
                <field name="title"/>
                <field name="body"/>
                <field name="notification_type"/>
                
                <separator/>
                <filter string="Unread" name="unread" domain="[('is_read', '=', False)]"/>
                <filter string="Read" name="read" domain="[('is_read', '=', True)]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_by_type" context="{'group_by': 'notification_type'}"/>
                    <filter string="Read Status" name="group_by_status" context="{'group_by': 'is_read'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_assetflow_notification" model="ir.actions.act_window">
        <field name="name">Notifications</field>
        <field name="res_model">assetflow.notification</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_assetflow_notification_search"/>
        <!-- By default, show unread messages first -->
        <field name="context">{'search_default_unread': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                You have no new notifications!
            </p>
        </field>
    </record>
</odoo>
